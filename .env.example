# ============================================================
# Business IQ Enterprise — Environment Variables
# ============================================================
# Copy this file to .env and fill in values for your deployment.
# DATABASE_URL is auto-injected by: agentuity cloud db create
# AGENTUITY_SDK_KEY is auto-set by the Agentuity project.
# ============================================================

# --- Infrastructure (auto-injected by Agentuity) ---
# DATABASE_URL=postgresql://...
# AGENTUITY_SDK_KEY=...

# --- AI Provider (optional — omit to use AI Gateway) ---
# LLM_PROVIDER_KEY=
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# PAYMENT INTEGRATIONS
# Set these per-client via: agentuity cloud env set KEY=value
# These are NEVER committed to source control.
# ============================================================

# --- M-Pesa (Safaricom Daraja API) ---
# Get credentials from: https://developer.safaricom.co.ke
# MPESA_ENABLED=true
# MPESA_ENVIRONMENT=sandbox         # sandbox | production
# MPESA_CONSUMER_KEY=               # From Daraja app
# MPESA_CONSUMER_SECRET=            # From Daraja app
# MPESA_SHORTCODE=                  # Till number or Paybill shortcode
# MPESA_PASSKEY=                    # From Daraja (Lipa Na M-Pesa passkey)
# MPESA_PAYMENT_TYPE=till           # till | paybill
# MPESA_TILL_NUMBER=                # Buy Goods till (if payment_type=till)
# MPESA_PAYBILL_NUMBER=             # Paybill number (if payment_type=paybill)
# MPESA_ACCOUNT_REFERENCE=          # e.g. "ShopName" shown on customer receipt
# MPESA_CALLBACK_URL=https://YOUR_DOMAIN/api/payments/mpesa/callback

# --- Paystack (Card Payments) ---
# Get credentials from: https://dashboard.paystack.com/#/settings/developers
# PAYSTACK_ENABLED=true
# PAYSTACK_PUBLIC_KEY=pk_test_...   # Frontend (safe to expose)
# PAYSTACK_SECRET_KEY=sk_test_...   # Backend only — NEVER expose
# PAYSTACK_CURRENCY=KES
# Paystack webhook IPs (whitelist in firewall): 52.31.139.75, 52.49.173.169, 52.214.14.220

# --- Analytics Sandbox ---
# ANALYTICS_SNAPSHOT_ID=            # Agentuity Python snapshot with pandas/numpy/etc.

# Analytics Service (optional - set to use FastAPI microservice instead of sandbox)
ANALYTICS_SERVICE_URL=
ANALYTICS_TIMEOUT_MS=60000

# --- Branding ---
COMPANY_NAME=Business IQ
COMPANY_LOGO_URL=
CURRENCY=USD
TAX_RATE=0.0
TIMEZONE=UTC

# --- Industry Terminology (labels displayed in UI) ---
PRODUCT_LABEL=Product
PRODUCT_LABEL_PLURAL=Products
ORDER_LABEL=Order
ORDER_LABEL_PLURAL=Orders
CUSTOMER_LABEL=Customer
CUSTOMER_LABEL_PLURAL=Customers
WAREHOUSE_LABEL=Warehouse
INVOICE_LABEL=Invoice
UNIT_DEFAULT=piece
