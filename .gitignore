# Dependencies
node_modules/
bun.lockb
bun.lock

# Build output
dist/
.agentuity/

# Prevent Windows path issues in cloud build
src/generated/*.ts

# Prevent Agentuity CLI bug: dotted filenames in src/web/public/ generate
# invalid TypeScript in src/generated/routes.ts (unquoted property names).
# Only subdirectories (e.g. icons/) are safe. No top-level dotted files.
src/web/public/*.js
src/web/public/*.json
src/web/public/*.ts
src/web/public/*.css
src/web/public/*.html
src/web/public/*.map

# Environment
.env
.env.local
.env.*.local

# Database
src/db/migrations/meta/

# Editor
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Saved webpage assets (browser _files/ folders)
docs/sanbox-optimization/**/*_files/

# Demo CSV data
demo/data/

# Logs
*.log
