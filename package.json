    "@agentuity/runtime": "latest",
    "@agentuity/schema": "latest",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/groq": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "docx": "^9.5.3",
