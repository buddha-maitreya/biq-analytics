{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"sourceMap": true,
		"jsx": "react-jsx",
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"types": [
			"bun"
		],
		"paths": {
			"@agent/*": [
				"./src/agent/*"
			],
			"@db/*": [
				"./src/db/*"
			],
			"@lib/*": [
				"./src/lib/*"
			],
			"@services/*": [
				"./src/services/*"
			],
			"@api/*": [
				"./src/api/*"
			],
			"@web/*": [
				"./src/web/*"
			],
			"@agentuity/runtime": [
				"./src/generated/router.ts"
			]
		},
		"outDir": "./dist"
	},
	"include": [
		"app.ts",
		"src/**/*.ts",
		"src/**/*.tsx"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
